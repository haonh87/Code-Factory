{
  "harnessId": "codex",
  "harnessLabel": "Codex CLI",
  "version": 1,
  "detection": {
    "homeDirMarker": ".codex",
    "envVar": "CODEX_HOME",
    "defaultHomeDir": ".codex"
  },
  "naming": {
    "globalAgentsFileName": "AGENTS.global.md",
    "projectAgentsFileName": "AGENTS.md",
    "managedSkillsManifestFile": ".codex-workflow-bundle.managed-skills.txt",
    "legacyManagedSkillsManifestFile": ".codex-workflow-pack.managed-skills.txt",
    "installStateFile": ".codex-workflow-bundle.install-state.json",
    "legacyInstallStateFile": ".codex-workflow-pack.install-state.json"
  },
  "paths": {
    "skillsHomeRel": "skills",
    "supportPoliciesTargetRoot": "policies/codex",
    "agentsDirectory": "agents",
    "agentsManifestFileName": "openai.yaml"
  },
  "content": {
    "globalAgentsSourceRel": "policies/codex/AGENTS.global.md",
    "skillsSourceRootRel": "skills",
    "supportPoliciesSourceRootRel": "policies/codex"
  },
  "runtime": {
    "installStateHomeKey": "codex_home"
  }
}